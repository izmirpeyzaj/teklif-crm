PORT=3000
GEMINI_API_KEY=your_api_key_here
JWT_SECRET=change_me_use_a_long_random_string
NODE_ENV=production

# --- E-posta (PDF gönderimi için gerekli) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM_NAME=Teklif

# --- PDF (Puppeteer) ---
# Sunucunun kendine ulaşacağı adres; Puppeteer teklif görsellerini/style.css'i buradan çeker.
# Docker/VPS'te genelde http://localhost:3000 doğru çalışır.
PUBLIC_ORIGIN=http://localhost:3000
# Docker'da sistem Chromium'unu kullan (Dockerfile bunu ayarlar):
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
